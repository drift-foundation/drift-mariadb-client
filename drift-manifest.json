{
  "schema_version": 1,
  "project": {
    "name": "drift-mariadb-client",
    "license": "MIT",
    "author_profile": "the-drift-foundation.author-profile"
  },
  "artifacts": [
    {
      "kind": "package",
      "name": "mariadb-wire-proto",
      "module_namespace": "mariadb.wire.proto",
      "version": "0.1.2",
      "description": "MariaDB wire protocol implementation for Drift",
      "entry_module": "packages/mariadb-wire-proto/src/lib.drift",
      "modules": [
        "packages/mariadb-wire-proto/src/lib.drift",
        "packages/mariadb-wire-proto/src/capabilities.drift",
        "packages/mariadb-wire-proto/src/errors.drift",
        "packages/mariadb-wire-proto/src/transport.drift",
        "packages/mariadb-wire-proto/src/types.drift",
        "packages/mariadb-wire-proto/src/command/com_ping.drift",
        "packages/mariadb-wire-proto/src/command/com_quit.drift",
        "packages/mariadb-wire-proto/src/command/com_query.drift",
        "packages/mariadb-wire-proto/src/command/com_reset_connection.drift",
        "packages/mariadb-wire-proto/src/decode/err_packet.drift",
        "packages/mariadb-wire-proto/src/decode/ok_packet.drift",
        "packages/mariadb-wire-proto/src/decode/resultset.drift",
        "packages/mariadb-wire-proto/src/handshake/auth.drift",
        "packages/mariadb-wire-proto/src/handshake/hello.drift",
        "packages/mariadb-wire-proto/src/packet/header.drift",
        "packages/mariadb-wire-proto/src/packet/lenenc.drift",
        "packages/mariadb-wire-proto/src/protocol/constants.drift"
      ],
      "assets": [
        "docs/integration-guide.md",
        "docs/effective-mariadb-wire-proto.md",
        "README.md"
      ]
    },
    {
      "kind": "package",
      "name": "mariadb-rpc",
      "module_namespace": "mariadb.rpc",
      "version": "0.1.2",
      "description": "Streaming stored-procedure RPC layer for MariaDB",
      "entry_module": "packages/mariadb-rpc/src/lib.drift",
      "modules": [
        "packages/mariadb-rpc/src/lib.drift"
      ],
      "package_deps": [
        {
          "name": "mariadb-wire-proto",
          "version": "0.1.2"
        }
      ],
      "assets": [
        "docs/integration-guide.md",
        "docs/effective-mariadb-rpc.md",
        "README.md"
      ]
    }
  ]
}
