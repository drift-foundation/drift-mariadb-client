// Step 2 correctness: a parked ManagedConnection.acquire waiter is woken when
// the outstanding lease is released (Condvar signal on _slot_put), and then
// obtains the freed conn — it does not wait out its full deadline.
//
// Two VTs: managed has a single slot, so the bug being guarded is a missed
// wakeup of an already-parked waiter, and a parked VT can't also perform the
// release. Main holds the sole conn; a second VT parks in acquire; main then
// releases. (Release uses the captured inner Arc, NOT the shared wrapper mutex,
// so it proceeds while the waiter holds the wrapper during its park.)
//
// On a correct build the waiter wakes ~immediately on release and returns 0.
// If the release signal were missing it would wait out its 5s deadline and
// return acquire-timeout (code 20) — caught by main as a non-zero waiter code.

module mariadb.rpc.tests.e2e.managed_release_wakeup_test;

import std.core as core;
import std.concurrent as conc;
import std.sync as sync;
import std.format as format;
import std.console as console;
import mariadb.rpc as rpc;
import mariadb.rpc.managed as managed;

const LIVE_HOST: String = "127.0.0.1";
const LIVE_PORT: Int = 34114;
const LIVE_USER: String = "root";
const LIVE_PASSWORD: String = "rootpw";
const LIVE_DB: String = "appdb";
const TIMEOUT_MS: Int = 1000;

fn _build_cfg() nothrow -> core.Result<rpc.RpcConnectionConfig, rpc.RpcConfigError> {
	var b = rpc.new_connection_config_builder();
	b.with_host(LIVE_HOST);
	b.with_port(LIVE_PORT);
	b.with_user(LIVE_USER);
	b.with_password(LIVE_PASSWORD);
	b.with_database(LIVE_DB);
	b.with_connect_timeout_ms(TIMEOUT_MS);
	b.with_read_timeout_ms(TIMEOUT_MS);
	b.with_write_timeout_ms(TIMEOUT_MS);
	b.with_autocommit(false);
	b.with_strict_reuse(true);
	return rpc.build_connection_config(move b);
}

fn _release_lease(lease: managed.LeasedConn) nothrow -> Void {
	val _ = move lease;
	return;
}

// Waiter VT: park in acquire until the lease is released, then prove the conn
// is usable. Holds the wrapper mutex for its run; releases it on return.
fn _waiter(shared: conc.Arc<conc.Mutex<managed.ManagedConnection> >, ready: conc.Arc<conc.AtomicBool>) nothrow -> Int {
	val mu: &conc.Mutex<managed.ManagedConnection> = shared.get();
	var guard = conc.lock(mu);
	val mc = guard.get_mut();
	val flag: &conc.AtomicBool = ready.get();
	flag.store(true, sync.MemoryOrder::Release());
	console.println("[waiter] calling acquire (expect to park on busy slot)");
	match mc.acquire(managed.AcquireWait::For(timeout = conc.Duration(millis = 5000))) {
		core.Result::Err(e) => { console.println("[waiter] acquire err: " + e.tag); return 20; },
		core.Result::Ok(lv) => {
			var lease = move lv;
			console.println("[waiter] woke + acquired the freed conn");
			match lease.conn() {
				core.Result::Err(_) => { return 21; },
				core.Result::Ok(c) => {
					match rpc.ping(c) {
						core.Result::Ok(_) => { console.println("[waiter] ping ok"); return 0; },
						core.Result::Err(e) => { console.println("[waiter] ping err: " + e.tag); return 22; }
					}
				}
			}
		}
	}
}

fn main() nothrow -> Int {
	console.println("=== managed_release_wakeup_test ===");
	match _build_cfg() {
		core.Result::Err(_) => { console.println("[main] config build failed"); return 1; },
		core.Result::Ok(cfg) => {
			var mcfg = managed.default_managed_config();
			mcfg.keepalive_interval_ms = 0;
			match managed.open(move cfg, move mcfg) {
				core.Result::Err(e) => { console.println("[main] open failed: " + e.tag); return 2; },
				core.Result::Ok(v) => {
					var mc = move v;
					match mc.acquire(managed.AcquireWait::For(timeout = conc.Duration(millis = 2000))) {
						core.Result::Err(e) => { console.println("[main] first acquire failed: " + e.tag); val _ = mc.close(); return 3; },
						core.Result::Ok(lv1) => {
							var lease1 = move lv1;
							console.println("[main] holding the sole managed conn");
							var shared: conc.Arc<conc.Mutex<managed.ManagedConnection> > = conc.arc(conc.mutex(move mc));
							var ready: conc.Arc<conc.AtomicBool> = conc.arc(conc.atomic_bool(false));
							var w: conc.Arc<conc.Mutex<managed.ManagedConnection> > = shared.clone();
							var w_ready: conc.Arc<conc.AtomicBool> = ready.clone();
							var cb: core.Callback0<Int> = core.callback0(| | captures(move w, move w_ready) => { return _waiter(move w, move w_ready); });
							var vt: conc.VirtualThread<Int> = conc.spawn(move cb);

							// Wait for the waiter's handshake, then settle so it has parked.
							val ready_flag: &conc.AtomicBool = ready.get();
							var waited_ms = 0;
							var handshaken = false;
							while not handshaken {
								if ready_flag.load(sync.MemoryOrder::Acquire()) {
									handshaken = true;
								} else {
									if waited_ms >= 2000 {
										console.println("[main] SETUP FAIL: waiter handshake not seen");
										_release_lease(move lease1);
										return 42;
									}
									val _ = conc.sleep(conc.Duration(millis = 5));
									waited_ms = waited_ms + 5;
								}
							}
							val _ = conc.sleep(conc.Duration(millis = 100));

							// Release the sole conn — the signal must wake the parked waiter.
							console.println("[main] releasing lease (signals the parked waiter)");
							_release_lease(move lease1);

							match vt.join_timeout(conc.Duration(millis = 8000)) {
								core.Result::Ok(code) => {
									console.println("[main] waiter joined, code=" + format.format_int(code));
									var g = conc.lock(shared.get());
									val _ = g.get_mut().close();
									if code != 0 { return code; }
								},
								core.Result::Err(e) => {
									console.println("[main] FAIL: waiter did not return within join deadline: " + e.kind);
									return 51;
								}
							}
						}
					}
				}
			}
		}
	}
	console.println("=== managed_release_wakeup_test: passed ===");
	return 0;
}
