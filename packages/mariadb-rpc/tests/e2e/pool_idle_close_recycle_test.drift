// Regression: poll_many keepalive fiber recycles a server-closed idle conn, and
// does NOT spuriously recycle a healthy leased+returned conn.
//
// Pins the generation-token (watch_token) behavior added with the poll_many
// keepalive rewrite (work/poll-many-keepalive/):
//   Phase 1 — CURRENT-token idle close recycles promptly via the POLL path.
//     We shrink the seeded conn's server-side wait_timeout (sp_set_wait_timeout)
//     so MariaDB autonomously closes it after ~2s idle. The fd then goes
//     readable/hangup; the poll fiber recycles it and emits IdleConnRecycled.
//     keepalive_interval is 60s here, so the periodic ping tick CANNOT fire in
//     the test window — any recycle observed is necessarily the poll path.
//   Phase 2 — STALE-token / healthy churn is NOT recycled.
//     Repeated acquire→ping→release of a healthy conn (default long wait_timeout)
//     must not produce any further IdleConnRecycled events: a leased/returned
//     conn re-enters `available` with a fresh token, and a healthy idle socket
//     has nothing readable, so the watcher leaves it alone.
//
// Needs sp_set_wait_timeout in tests/fixtures/appdb_schema.sql.

module mariadb.rpc.tests.e2e.pool_idle_close_recycle_test;

import std.core as core;
import std.concurrent as conc;
import std.format as format;
import std.console as console;
import mariadb.rpc as rpc;
import mariadb.rpc.managed as managed;
import mariadb.rpc.pool as pool;

const LIVE_HOST: String = "127.0.0.1";
const LIVE_PORT: Int = 34114;
const LIVE_USER: String = "root";
const LIVE_PASSWORD: String = "rootpw";
const LIVE_DB: String = "appdb";
const LIVE_TIMEOUT_MS: Int = 1000;

// Server closes the conn ~this many seconds after it goes idle.
const WAIT_TIMEOUT_SECS: Int = 2;
// Upper bound to observe the recycle: wait_timeout + poll detection (<=1s cap) +
// slack. Far below the 60s keepalive interval, so a hit proves the poll path.
const RECYCLE_DEADLINE_MS: Int = 12000;
const POLL_STEP_MS: Int = 100;

pub struct PoolEventCounter {
	pub recycled: Int,
	pub opened: Int
}

fn _build_cfg() nothrow -> core.Result<rpc.RpcConnectionConfig, rpc.RpcConfigError> {
	var b = rpc.new_connection_config_builder();
	b.with_host(LIVE_HOST);
	b.with_port(LIVE_PORT);
	b.with_user(LIVE_USER);
	b.with_password(LIVE_PASSWORD);
	b.with_database(LIVE_DB);
	b.with_connect_timeout_ms(LIVE_TIMEOUT_MS);
	b.with_read_timeout_ms(LIVE_TIMEOUT_MS);
	b.with_write_timeout_ms(LIVE_TIMEOUT_MS);
	b.with_autocommit(false);
	b.with_strict_reuse(true);
	return rpc.build_connection_config(move b);
}

fn _make_sink(counter_for_sink: conc.Arc<conc.Mutex<PoolEventCounter> >) nothrow -> core.Callback1<pool.PoolEvent, Void> {
	return core.callback1(|ev: pool.PoolEvent| captures(move counter_for_sink) => {
		match ev {
			pool.PoolEvent::IdleConnRecycled(n) => {
				val mu_ref: &conc.Mutex<PoolEventCounter> = counter_for_sink.get();
				var guard = conc.lock(mu_ref);
				val s = guard.get_mut();
				s.recycled = s.recycled + n;
			},
			pool.PoolEvent::ConnOpened(_) => {
				val mu_ref: &conc.Mutex<PoolEventCounter> = counter_for_sink.get();
				var guard = conc.lock(mu_ref);
				val s = guard.get_mut();
				s.opened = s.opened + 1;
			},
			pool.PoolEvent::ConnClosedByReap(_) => {},
			pool.PoolEvent::KeepalivePingOk => {},
			pool.PoolEvent::KeepalivePingFailed(_) => {},
			pool.PoolEvent::ReconnectAttempt(_) => {},
			pool.PoolEvent::ReconnectSucceeded(_) => {},
			pool.PoolEvent::ReconnectFailed(_, _) => {},
			pool.PoolEvent::AcquireWaiting(_) => {},
			pool.PoolEvent::AcquireUnblocked => {}
		}
		return;
	});
}

fn _recycled_count(counter: &conc.Arc<conc.Mutex<PoolEventCounter> >) nothrow -> Int {
	val mu_ref: &conc.Mutex<PoolEventCounter> = counter.get();
	var guard = conc.lock(mu_ref);
	return guard.get_mut().recycled;
}

// Acquire one conn and run sp_set_wait_timeout(secs) on it, then drop the lease
// so it returns to the pool and sits idle. Returns 0 on success, else a code.
fn _arm_short_timeout(p: &pool.ConnectionPool, secs: Int) nothrow -> Int {
	match p.acquire(managed.AcquireWait::For(timeout = conc.Duration(millis = 5000))) {
		core.Result::Err(e) => { console.println("[arm] acquire failed: " + e.tag); return 110; },
		core.Result::Ok(lv) => {
			var lease = move lv;
			match lease.conn() {
				core.Result::Err(_) => { return 111; },
				core.Result::Ok(c) => {
					var args: Array<rpc.RpcArg> = [];
					args.push(rpc.arg_int(secs));
					match c.call(&"sp_set_wait_timeout", &args) {
						core.Result::Ok(s) => { val _ = move s; },  // drain the (resultless) CALL
						core.Result::Err(e) => { console.println("[arm] sp_set_wait_timeout failed: " + e.tag); return 112; }
					}
				}
			}
			// lease drops here → conn back to available, now idle with wait_timeout=secs
			return 0;
		}
	}
}

// One healthy acquire→ping→release cycle. Returns 0 on success.
fn _healthy_cycle(p: &pool.ConnectionPool) nothrow -> Int {
	match p.acquire(managed.AcquireWait::For(timeout = conc.Duration(millis = 5000))) {
		core.Result::Err(e) => { console.println("[churn] acquire failed: " + e.tag); return 120; },
		core.Result::Ok(lv) => {
			var lease = move lv;
			match lease.conn() {
				core.Result::Err(_) => { return 121; },
				core.Result::Ok(c) => {
					match rpc.ping(c) {
						core.Result::Ok(_) => {},
						core.Result::Err(e) => { console.println("[churn] ping failed: " + e.tag); return 122; }
					}
				}
			}
			return 0;
		}
	}
}

fn main() nothrow -> Int {
	console.println("=== pool_idle_close_recycle_test ===");
	match _build_cfg() {
		core.Result::Err(_) => { console.println("[main] config build failed"); return 1; },
		core.Result::Ok(cfg) => {
			var counter_arc: conc.Arc<conc.Mutex<PoolEventCounter> > = conc.arc(conc.mutex(PoolEventCounter(recycled = 0, opened = 0)));
			var pc = pool.default_pool_config();
			pc.min_idle = 0;
			pc.max_conns = 2;
			pc.keepalive_interval_ms = 60000;   // ping tick won't fire in-window → isolates poll path
			pc.idle_timeout_ms = 600000;        // idle reap won't fire either
			pc.event_sink = Optional::Some(_make_sink(counter_arc.clone()));
			match pool.open(move cfg, move pc) {
				core.Result::Err(e) => { console.println("[main] open failed: " + e.tag); return 2; },
				core.Result::Ok(v) => {
					var p = move v;

					// --- Phase 1: arm short server timeout, then watch for recycle ---
					val arm_rc = _arm_short_timeout(&p, WAIT_TIMEOUT_SECS);
					if arm_rc != 0 { val _ = p.close(); return arm_rc; }
					console.println("[phase1] conn armed with wait_timeout=" + format.format_int(WAIT_TIMEOUT_SECS) + "s; awaiting server close + poll recycle");

					var waited = 0;
					var recycled_seen = false;
					while not recycled_seen {
						if _recycled_count(&counter_arc) >= 1 {
							recycled_seen = true;
						} else {
							if waited >= RECYCLE_DEADLINE_MS {
								console.println("[phase1] FAIL: no IdleConnRecycled within " + format.format_int(RECYCLE_DEADLINE_MS) + "ms");
								val _ = p.close();
								return 3;
							}
							val _ = conc.sleep(conc.Duration(millis = POLL_STEP_MS));
							waited = waited + POLL_STEP_MS;
						}
					}
					console.println("[phase1] PASS: idle conn recycled by poll path after ~" + format.format_int(waited) + "ms (<< 60s keepalive)");

					// --- Phase 2: healthy churn must NOT trigger further recycles ---
					val baseline = _recycled_count(&counter_arc);
					var i = 0;
					while i < 6 {
						val rc = _healthy_cycle(&p);
						if rc != 0 { val _ = p.close(); return rc; }
						val _ = conc.sleep(conc.Duration(millis = 400));
						i = i + 1;
					}
					val after = _recycled_count(&counter_arc);
					if after != baseline {
						console.println("[phase2] FAIL: healthy churn caused " + format.format_int(after - baseline) + " spurious recycle(s)");
						val _ = p.close();
						return 4;
					}
					console.println("[phase2] PASS: healthy leased+returned conn not spuriously recycled (recycled stable at " + format.format_int(after) + ")");

					match p.close() {
						core.Result::Err(_) => { return 5; },
						core.Result::Ok(_) => {}
					}
				}
			}
		}
	}
	console.println("=== pool_idle_close_recycle_test: passed ===");
	return 0;
}
